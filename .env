# Server configuration
PORT=5000

# JWT Token Secret
JWT_SECRET=supersecretjwtkey12345!@#$

# MongoDB Connection URI (Optional)
# If empty, the server automatically falls back to a local JSON file database under server/data/db.json
MONGO_URI=mongodb://localhost:27017/chatapp

# Google Gemini AI API Key (Optional)
# Get a key from: https://aistudio.google.com/
# If left blank, the Gemini assistant will reply with a helpful simulation response.
GEMINI_API_KEY=
